# Local Docker Postgres (not needed on Netlify — use Netlify Database instead)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cest_moi_le_chef
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cest_moi_le_chef"

# Better Auth
# Generate a secret with: openssl rand -hex 32
BETTER_AUTH_SECRET=
# The URL this app is served from (e.g. http://localhost:3000 or https://your-site.netlify.app)
BETTER_AUTH_URL=

# Cloudflare R2 (required for Cover Image uploads)
# Account ID: Cloudflare dashboard → R2 → Overview
R2_ACCOUNT_ID=
# Create an API token with Object Read & Write at: Cloudflare dashboard → R2 → Manage R2 API tokens
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# The name of your R2 bucket
R2_BUCKET_NAME=
# The public URL of your R2 bucket (enable public access on the bucket to get this)
R2_PUBLIC_URL=
