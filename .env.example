# Local Postgres credentials - used by docker-compose (pnpm db:up) and DATABASE_URL below
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=cest_moi_le_chef

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cest_moi_le_chef

# Local dev server URL
BETTER_AUTH_URL=http://localhost:3000

# Any string works for local dev; use a strong random secret in production (openssl rand -base64 32)
BETTER_AUTH_SECRET=dev-secret

# Cloudflare R2 - required for image uploads even in local dev
# Create an R2 bucket and API token at https://dash.cloudflare.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
