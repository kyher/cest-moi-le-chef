# Neon database connection string (get from neon.tech dashboard)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Local dev server URL / production Vercel URL
BETTER_AUTH_URL=http://localhost:3000

# Any string works for local dev; use a strong random secret in production (openssl rand -base64 32)
BETTER_AUTH_SECRET=dev-secret

# Cloudflare R2 - required for image uploads even in local dev
# Create an R2 bucket and API token at https://dash.cloudflare.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
