{
	"name": "cest-moi-le-chef",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "prisma generate && prisma migrate deploy && vite build",
		"preview": "vite preview",
		"test": "pnpm db:test:up && pnpm db:migrate:test && dotenv -e .env.test.local -- vitest run",
		"db:test:up": "docker compose up -d --wait",
		"db:test:down": "docker compose down",
		"db:migrate:test": "dotenv -e .env.test.local -- prisma migrate deploy",
		"post-cta-init": "pnpm dlx create-db@latest --user-agent tanstack/tsrouter",
		"db:generate": "dotenv -e .env.local -- prisma generate",
		"db:push": "dotenv -e .env.local -- prisma db push",
		"db:migrate": "dotenv -e .env.local -- prisma migrate dev",
		"db:studio": "dotenv -e .env.local -- prisma studio",
		"lint": "biome check --write .",
		"lint:ci": "biome ci .",
		"db:seed": "dotenv -e .env.local -- prisma db seed",
		"start": "vite preview --port 3000"
	},
	"dependencies": {
		"@aws-sdk/client-s3": "^3.1073.0",
		"@neondatabase/serverless": "^1.1.0",
		"@prisma/adapter-neon": "^7.8.0",
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@tailwindcss/vite": "^4.3.1",
		"@tanstack/react-devtools": "latest",
		"@tanstack/react-router": "latest",
		"@tanstack/react-router-devtools": "latest",
		"@tanstack/react-router-ssr-query": "latest",
		"@tanstack/react-start": "latest",
		"@tanstack/router-plugin": "^1.168.18",
		"better-auth": "^1.6.20",
		"i18next": "^26.3.2",
		"i18next-browser-languagedetector": "^8.2.1",
		"lucide-react": "^0.545.0",
		"prisma": "^7.8.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-i18next": "^17.0.8",
		"sonner": "^2.0.7",
		"tailwindcss": "^4.3.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@tailwindcss/typography": "^0.5.20",
		"@tanstack/devtools-vite": "latest",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "^22.20.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"dotenv-cli": "^11.0.0",
		"jsdom": "^28.1.0",
		"nitro": "3.0.260610-beta",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"packageManager": "pnpm@11.4.0"
}
